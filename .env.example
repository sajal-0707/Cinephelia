# ─────────────────────────────────────────
#  Server
# ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────
#  MongoDB
# ─────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/movie_booking
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/movie_booking?retryWrites=true&w=majority

# ─────────────────────────────────────────
#  Session
# ─────────────────────────────────────────
SESSION_SECRET=your_super_secret_session_key_change_in_production

# ─────────────────────────────────────────
#  Google OAuth 2.0
#  Create credentials at: https://console.cloud.google.com/apis/credentials
#  Authorised redirect URI: http://localhost:5000/api/auth/google/callback
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─────────────────────────────────────────
#  Client (frontend URL for redirects)
# ─────────────────────────────────────────
CLIENT_URL=http://localhost:3000
